---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import StickyNav from "../components/StickyNav.astro";
import SkipLink from "../components/SkipLink.astro";
import BlogCard from "../components/BlogCard.astro";
import meImage from "../assets/me.png";
import { Icon } from "astro-icon/components";
import apiPlatformIcon from "../assets/icons/api-platform.svg";
import cicdIcon from "../assets/icons/cicd.svg";

type ProjectCard = {
  title: string;
  description: string;
  tags: string[];
  image?: string;
  type: string;
  github?: string;
  demo?: string;
};

const blogPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);
const featuredPost = blogPosts.find((p) => p.data.featured) ?? blogPosts[0];
const sidePosts = blogPosts
  .filter((p) => p.slug !== featuredPost?.slug)
  .slice(0, 2);

const projects: ProjectCard[] = (await getCollection("projects"))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .map((project) => ({
    title: project.data.title,
    description: project.data.description,
    tags: project.data.tags,
    image: project.data.coverImage?.src,
    type: project.data.type ?? "Side Project",
    github: project.data.githubUrl,
    demo: project.data.url,
  }));
---

<BaseLayout>
  <SkipLink />
  <StickyNav />

  <main id="main-content">
    <section class="hero" id="hero">
      <div class="hero-orb hero-orb-1"></div>
      <div class="hero-orb hero-orb-2"></div>
      <div class="hero-wrapper">
        <div class="hero-content">
          <div class="hero-visual fade-up delay-2">
            <div class="avatar-wrap">
              <Image
                src={meImage}
                alt="Cédric Matyja en Pixel Art"
                class="avatar-img"
              />
              <div class="avatar-ring"></div>
              <div class="avatar-glow"></div>
            </div>
          </div>

          <div>
            <h1 class="fade-up delay-1">
              Cédric <em>Matyja</em><br />
              développeur<em><br />fullstack</em>
            </h1>

            <p class="hero-desc fade-up delay-2">
              Basé près de Lille, je suis spécialisé en PHP / Symfony,
              TypeScript / Vue.js / React.js et Python.
            </p>

            <div class="hero-actions fade-up delay-3">
              <a
                href="https://www.linkedin.com/in/c-matyja/"
                target="_blank"
                rel="noopener"
                class="social-btn linkedin"
                aria-label="LinkedIn - Cedric Matyja"
              >
                <Icon name="simple-icons:linkedin" class="social-icon" />
                <span class="social-tooltip">LinkedIn</span>
              </a>
              <a
                href="https://github.com/cajytam"
                target="_blank"
                rel="noopener"
                class="social-btn github"
                aria-label="GitHub - Cedric Matyja"
              >
                <Icon name="simple-icons:github" class="social-icon" />
                <span class="social-tooltip">GitHub</span>
              </a>
              <a
                href="https://gitlab.com/cmatyja"
                target="_blank"
                rel="noopener"
                class="social-btn gitlab"
                aria-label="GitLab - Cedric Matyja"
              >
                <Icon name="simple-icons:gitlab" class="social-icon" />
                <span class="social-tooltip">GitLab</span>
              </a>
              <a href="/blog" class="btn btn-primary">
                <Icon name="simple-icons:files" class="blog-btn-icon" />
                Mon blog
              </a>
            </div>

            <div class="hero-stats fade-up delay-3">
              <div>
                <div class="stat-val">
                  {Math.floor(new Date().getFullYear() - 2013.5)}+
                </div>
                <div class="stat-label">
                  ans à<br />transformer des<br />idées en produits
                </div>
              </div>
              <div>
                <div class="stat-val">
                  {Math.floor(new Date().getFullYear() - 2021)}+
                </div>
                <div class="stat-label">
                  ans à<br />concevoir des<br />applications web
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="parcours" id="parcours">
      <div class="section-wrapper">
        <div class="section-tag">Expériences</div>
        <h2 class="section-title">Mon <em>parcours</em><br />professionnel</h2>
        <p class="section-sub">
          16 ans d'expérience alliant comptabilité, administration système
          d'informations et développement fullstack - avec une expertise en
          Symfony, React et automatisation (en Python et VBA).
        </p>

        <div class="tl-wrap">
          <div></div>
          <div class="tl-entries">
            {
              [
                {
                  year: "2024 - Présent",
                  role: "Développeur Full Stack",
                  company: "Cheef.fr · Roncq",
                  desc: [
                    "Réalisation d'une application de gestion et suivi des leads en React et Symfony / API Platform",
                    "Application de saisie et suivi des tickets SAV avec KPI associés",
                    "Implémentation de Mercure pour l'affichage temps-réel du statut Aircall dans PrestaShop en SSE",
                    "Consommation d'API et webhooks (Brevo, Aircall)",
                    "Automatisation de production avec Docker Compose",
                  ],
                  tags: [
                    "React",
                    "Symfony",
                    "API Platform",
                    "Prestashop",
                    "Docker",
                    "Mercure",
                  ],
                },
                {
                  year: "2023 - 2024",
                  role: "Développeur Web",
                  company: "Enbro France / Earth Solar France · Roncq",
                  desc: [
                    "Conception et développement d'un CRM de gestion de prospects et projets photovoltaïques",
                    "Génération automatisée de devis détaillés avec implantation, dimensionnement et calcul d'amortissement",
                    "Gestion complète des projets d'installation et documents administratifs",
                    "Mise en production et maintenance évolutive",
                  ],
                  tags: ["Vue.js", "Symfony", "API Platform", "MySQL"],
                },
                {
                  year: "2022 - 2023",
                  role: "Analyste Programmeur EDI",
                  company: "Dornach France (groupe Ziegler) · Roncq",
                  desc: [
                    "Développement de programmes de traduction de fichiers (plats ou normés) sous TradeXpress en langage RTE",
                    "Gestion des tickets sous Jira",
                  ],
                  tags: ["RTE", "TradeXpress", "EDI", "Jira"],
                },
                {
                  year: "2019 - 2022",
                  role: "Développeur Web",
                  company: "Association Noémi · Roubaix",
                  desc: [
                    "Refonte du site web de l'association sous Symfony",
                    "Conception et modélisation en UML",
                    "Wireframes, design et intégration du front-end",
                    "Gestion des utilisateurs et actualités via back-office sécurisé",
                    "Génération de reçus fiscaux en PDF et envoi par mail",
                    "Tests unitaires et fonctionnels, mise en ligne du site",
                  ],
                  tags: ["Symfony", "UML", "PDF Generation", "Back-office"],
                },
                {
                  year: "2013 - 2022",
                  role: "Administrateur SI Finance Amélioration Continue",
                  company: "Castorama France SAS · Templamars",
                  desc: [
                    "Administration des logiciels comptables (CODA et SAP)",
                    "Développement d'outils en Python ou VBA (sous Access et Excel) afin d'automatiser, d'optimiser et de fiabiliser les traitements et les saisies en masse",
                  ],
                  tags: ["Python", "VBA", "SAP", "CODA"],
                },
                {
                  year: "2010 - 2013",
                  role: "Comptable",
                  company: "Castorama France SAS · Templamars",
                  desc: [
                    "Saisie / rapprochement et règlement des factures fournisseurs",
                    "Cadrage URSSAF et TVA, pointage des comptes de paie et participation aux clôtures mensuelles et annuelles",
                  ],
                  tags: ["Comptabilité", "Gestion Administrative"],
                  last: true,
                },
              ].map((item) => (
                <div class="tl-entry">
                  <div class="tl-entry-year">{item.year}</div>
                  <div
                    class:list={[
                      "tl-entry-body",
                      item.last && "tl-entry-body--last",
                    ]}
                  >
                    <div class="tl-role">{item.role}</div>
                    <div class="tl-company">{item.company}</div>
                    <ul class="tl-desc">
                      {Array.isArray(item.desc) ? (
                        item.desc.map((point) => <li>{point}</li>)
                      ) : (
                        <li>{item.desc}</li>
                      )}
                    </ul>
                    <div class="tl-tags">
                      {item.tags.map((t) => (
                        <span class="tag">{t}</span>
                      ))}
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section id="formation">
      <div class="section-wrapper">
        <div class="section-tag">Parcours académique</div>
        <h2 class="section-title">Diplômes &<br /><em>formations</em></h2>
        <p class="section-sub">
          Un parcours combinant comptabilité et développement informatique,
          complété par des formations continues (veille technologique et cours
          sur Udemy) pour rester à jour.
        </p>

        <div class="tl-wrap tl-formation">
          <div></div>
          <div class="tl-entries">
            {
              [
                {
                  year: "2019",
                  role: "Licence - Concepteur Développeur d'Applications",
                  company: "M2i Formation Diplômante · Villeneuve d'Ascq",
                  desc: [],
                  tags: [
                    "PHP",
                    "Symfony",
                    "JavaScript",
                    "Java",
                    "UML",
                    "Scrum",
                  ],
                },
                {
                  year: "2009",
                  role: "Licence - Diplôme Comptable et de Gestion (DCG)",
                  company: "Lycée Malraux · Béthune",
                  desc: [],
                  tags: [
                    "Comptabilité",
                    "Suite Office",
                    "Contrôle de Gestion",
                    "Informatique de Gestion",
                  ],
                  last: true,
                },
              ].map((item) => (
                <div class="tl-entry">
                  <div class="tl-entry-year">{item.year}</div>
                  <div
                    class:list={[
                      "tl-entry-body",
                      item.last && "tl-entry-body-last",
                    ]}
                  >
                    <div class="tl-role">{item.role}</div>
                    <div class="tl-company">{item.company}</div>
                    <ul class="tl-desc">
                      {Array.isArray(item.desc) ? (
                        item.desc.map((point) => <li>{point}</li>)
                      ) : (
                        <li>{item.desc}</li>
                      )}
                    </ul>
                    <div class="tl-tags">
                      {item.tags.map((t) => (
                        <span class="tag">{t}</span>
                      ))}
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="stack" id="stack">
      <div class="section-wrapper">
        <div class="section-tag">Technologies</div>
        <h2 class="section-title">Ma <em>stack</em><br />technique</h2>
        <p class="section-sub">
          Des technologies modernes et éprouvées pour créer des applications web
          robustes et performantes.
        </p>

        <div class="stack-universe">
          <div class="stack-categories">
            {
              [
                {
                  label: "Frontend",
                  cls: "cat-front",
                  items: [
                    ["simple-icons:typescript", "TypeScript"],
                    ["simple-icons:vuedotjs", "Vue.js"],
                    ["simple-icons:react", "React"],
                    ["simple-icons:tailwindcss", "Tailwind"],
                    ["simple-icons:symfony", "Symfony UX"],
                    ["simple-icons:astro", "Astro"],
                  ],
                },
                {
                  label: "Backend",
                  cls: "cat-back",
                  items: [
                    ["simple-icons:php", "PHP"],
                    ["simple-icons:symfony", "Symfony"],
                    ["custom:api-platform", "API Platform"],
                    ["simple-icons:prestashop", "PrestaShop"],
                    ["simple-icons:python", "Python"],
                    ["simple-icons:fastapi", "FastAPI"],
                  ],
                },
                {
                  label: "Data",
                  cls: "cat-data",
                  items: [
                    ["simple-icons:mysql", "MySQL"],
                    ["simple-icons:postgresql", "PostgreSQL"],
                    ["simple-icons:prisma", "Prisma"],
                  ],
                },
                {
                  label: "Infra & Tooling",
                  cls: "cat-infra",
                  items: [
                    ["simple-icons:docker", "Docker"],
                    ["custom:cicd", "CI/CD"],
                    ["simple-icons:github", "GitHub"],
                    ["simple-icons:vite", "Vite"],
                    ["simple-icons:jira", "Jira"],
                  ],
                },
              ].map((cat) => (
                <div>
                  <div class="stack-cat-label">{cat.label}</div>
                  <div class="stack-pills">
                    {cat.items.map(([iconName, name]) => {
                      const isCustom = iconName.startsWith("custom:");
                      const customIcon = isCustom
                        ? iconName.split(":")[1]
                        : null;
                      return (
                        <div class:list={["stack-pill", cat.cls]}>
                          <span class="sp-dot" />
                          {isCustom ? (
                            <img
                              src={
                                customIcon === "api-platform"
                                  ? apiPlatformIcon.src
                                  : cicdIcon.src
                              }
                              alt={name}
                              class="sp-logo sp-logo-custom"
                            />
                          ) : (
                            <Icon name={iconName} class="sp-logo" />
                          )}
                          {name}
                        </div>
                      );
                    })}
                  </div>
                </div>
              ))
            }
          </div>

          <div class="stack-featured">
            <div class="sf-header">
              <div class="sf-header-dot"></div>
              Stack favorite - usage quotidien
            </div>
            <div class="sf-items">
              {
                [
                  {
                    rank: "01",
                    icon: "simple-icons:symfony",
                    name: "Symfony + API Platform",
                    desc: "Framework PHP de référence pour les APIs",
                    exp: "5+ ans",
                  },
                  {
                    rank: "02",
                    icon: "simple-icons:vuedotjs",
                    name: "Vue.js + TypeScript",
                    desc: "Framework réactif pour interfaces modernes",
                    exp: "3 ans",
                  },
                  {
                    rank: "03",
                    icon: "simple-icons:react",
                    name: "React",
                    desc: "Applications web dynamiques et SPAs",
                    exp: "2 ans",
                  },
                  {
                    rank: "04",
                    icon: "simple-icons:postgresql",
                    name: "PostgreSQL",
                    desc: "Base de données relationnelle puissante",
                    exp: "4 ans",
                  },
                  {
                    rank: "05",
                    icon: "simple-icons:docker",
                    name: "Docker",
                    desc: "Containerisation et environnements isolés",
                    exp: "3 ans",
                  },
                ].map((item) => (
                  <div class="sf-item">
                    <div class="sf-rank">{item.rank}</div>
                    <Icon name={item.icon} class="sf-icon-img" />
                    <div class="sf-info">
                      <div class="sf-name">{item.name}</div>
                      <div class="sf-desc">{item.desc}</div>
                    </div>
                    <div class="sf-exp">{item.exp}</div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="projects" id="projects">
      <div class="section-wrapper">
        <div class="section-tag">Portfolio</div>
        <h2 class="section-title">Mes <em>projets</em></h2>
        <p class="section-sub">
          Projets personnels, proof of concept et side projects
        </p>

        <div class="projects-grid">
          {
            projects.map((project) => (
              <div class="project-card">
                <div class="project-image">
                  {project.image ? (
                    <img src={project.image} alt={project.title} />
                  ) : (
                    <div class="project-image-placeholder">🚀</div>
                  )}
                  <span class="project-type">{project.type}</span>
                </div>
                <div class="project-content">
                  <h3 class="project-title">{project.title}</h3>
                  <p class="project-desc">{project.description}</p>
                  <div class="project-tags">
                    {project.tags.map((tag) => (
                      <span class="project-tag">{tag}</span>
                    ))}
                  </div>
                </div>
                <div class="project-footer">
                  {project.github && (
                    <a
                      href={project.github}
                      target="_blank"
                      rel="noopener"
                      class="project-link github-link"
                      aria-label="GitHub"
                    >
                      <Icon name="simple-icons:github" class="project-icon" />
                    </a>
                  )}
                  {project.demo && (
                    <a
                      href={project.demo}
                      target="_blank"
                      rel="noopener"
                      class="project-link demo-link"
                      aria-label="Live Demo"
                    >
                      <Icon
                        name="simple-icons:firefoxbrowser"
                        class="project-icon"
                      />
                    </a>
                  )}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="blog" id="blog">
      <div class="section-wrapper">
        <div class="section-tag">Écrits</div>
        <h2 class="section-title">Derniers<br /><em>articles</em></h2>
        <p class="section-sub">
          Je partage ici mes expériences, mes projets et mes réflexions autour
          du développement web et des technologies que j’explore au quotidien.
        </p>

        {
          blogPosts.length > 0 ? (
            <div class="blog-grid">
              {featuredPost && (
                <BlogCard
                  slug={featuredPost.slug}
                  size="lg"
                  {...featuredPost.data}
                />
              )}
              <div class="blog-right">
                {sidePosts.map((post) => (
                  <BlogCard slug={post.slug} size="sm" {...post.data} />
                ))}
              </div>
            </div>
          ) : (
            <p style="color:var(--text)">Aucun article pour l'instant.</p>
          )
        }

        <div style="margin-top:40px; text-align:center;">
          <a href="/blog" class="btn btn-ghost">Voir tous les articles →</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /****** HERO ********/

  .hero {
    position: relative;
    display: flex;
    align-items: center;
    padding: 12rem clamp(2.4rem, 5vw, 8rem) 8rem;
    overflow: hidden;
  }

  .hero-wrapper {
    width: 100%;
    max-width: 144rem;
    margin: 0 auto;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: start;
    width: 100%;
  }

  .hero-orb {
    position: absolute;
    pointer-events: none;
    border-radius: 50%;
    filter: blur(10rem);
  }

  .hero-orb-1 {
    top: -10rem;
    right: -10rem;
    width: 60rem;
    height: 60rem;
    background: radial-gradient(
      circle,
      rgb(59 130 246 / 12%) 0%,
      transparent 70%
    );
  }

  .hero-orb-2 {
    bottom: 0;
    left: 20rem;
    width: 40rem;
    height: 40rem;
    background: radial-gradient(
      circle,
      rgb(96 165 250 / 8%) 0%,
      transparent 70%
    );
  }

  .hero h1 {
    margin-bottom: 2.4rem;
    font-family: "DM Serif Display", serif;
    font-size: clamp(5rem, 7vw, 8.4rem);
    line-height: 1.05;
    letter-spacing: -0.2rem;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--accent2);
  }

  .hero-desc {
    max-width: 44rem;
    margin-bottom: 4rem;
    font-size: 1.9rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--text2);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .social-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4.8rem;
    height: 4.8rem;
    color: var(--text);
    text-decoration: none;
    cursor: pointer;
    background: var(--bg3);
    border: 1.5px solid var(--border2);
    border-radius: 50%;
    transition: all 0.3s ease;
  }

  .social-btn svg {
    width: 2rem;
    height: 2rem;
    fill: currentcolor;
  }

  .social-icon {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
  }

  .social-btn:hover {
    box-shadow: 0 0.8rem 2.4rem rgb(0 0 0 / 30%);
    transform: translateY(-0.3rem);
  }

  .social-tooltip {
    position: absolute;
    top: 50%;
    left: 50%;
    visibility: hidden;
    padding: 0.8rem 1.2rem;
    font-size: 1.1rem;
    line-height: 1rem;
    color: white;
    white-space: nowrap;
    pointer-events: none;
    border-radius: 0.6rem;
    opacity: 0;
    transform: translate(-50%, -140%);
    transition: all 0.3s ease;
  }

  .social-tooltip::after {
    position: absolute;
    bottom: -0.5rem;
    left: 50%;
    width: 0;
    height: 0;
    content: "";
    border-right: 0.5rem solid transparent;
    border-left: 0.5rem solid transparent;
    transform: translateX(-50%);
  }

  .social-btn.linkedin:hover {
    color: #0a66c2;
    border-color: #0a66c2;
  }

  .social-btn.linkedin .social-tooltip {
    background: #0a66c2;
  }

  .social-btn.linkedin .social-tooltip::after {
    border-top-color: #0a66c2;
  }

  .social-btn.github:hover {
    color: #333;
    border-color: #333;
  }

  .social-btn.github .social-tooltip {
    background: #333;
  }

  .social-btn.github .social-tooltip::after {
    border-top-color: #333;
  }

  .social-btn.gitlab:hover {
    color: #fc6d26;
    border-color: #fc6d26;
  }

  .social-btn.gitlab .social-tooltip {
    background: #fc6d26;
  }

  .social-btn.gitlab .social-tooltip::after {
    border-top-color: #fc6d26;
  }

  .social-btn:hover .social-tooltip {
    visibility: visible;
    opacity: 1;
    transform: translate(-50%, -155%);
  }

  .hero-stats {
    display: flex;
    gap: 3.2rem;
    padding-top: 3.2rem;
    margin-top: 4.8rem;
    border-top: 1px solid var(--border);
  }

  .stat-val {
    font-family: "DM Serif Display", serif;
    font-size: 3.6rem;
    line-height: 1.2;
    letter-spacing: -0.1rem;
  }

  .stat-label {
    margin-top: 0.2rem;
    font-size: 1.2rem;
    color: var(--text2);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /****** AVATAR ********/

  .hero-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .avatar-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 42rem;
    aspect-ratio: 1 / 1.15;
  }

  .avatar-img {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    background: var(--bg2);
    border: 1px solid var(--border2);
    border-radius: 2.4rem;
    box-shadow: 0 4rem 8rem rgb(0 0 0 / 50%);
  }

  .avatar-ring {
    position: absolute;
    inset: -0.8rem;
    z-index: 1;
    background: linear-gradient(
        135deg,
        rgb(59 130 246 / 35%),
        rgb(96 165 250 / 10%),
        transparent 60%
      )
      border-box;
    border: 1px solid transparent;
    border-radius: 3.2rem;
    mask:
