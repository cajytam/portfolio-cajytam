---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import AppHeader from "../../components/AppHeader.astro";
import Footer from "../../components/Footer.astro";
import { Icon } from "astro-icon/components";

const projects = (await getCollection("projects")).sort(
  (a, b) =>
    new Date(b.data.publishedAt).getTime() -
    new Date(a.data.publishedAt).getTime(),
);
---

<BaseLayout
  title="Projets — Cédric Matyja"
  description="Mes projets et réalisations"
>
  <AppHeader mode="page" />

  <main class="min-h-screen pt-16">
    <section class="mx-auto max-w-7xl px-6 py-24 lg:px-12">
      <div class="mb-16 max-w-2xl">
        <div
          class="mb-4 text-sm font-medium tracking-wider text-indigo-500 dark:text-indigo-400"
        >
          RÉALISATIONS
        </div>
        <h1
          class="mb-6 font-serif text-5xl font-bold text-zinc-900 lg:text-6xl dark:text-zinc-50"
        >
          Mes projets
        </h1>
        <p class="text-lg text-zinc-600 dark:text-zinc-400">
          Une sélection de projets personnels et professionnels axés sur la
          qualité de code, la performance et l'expérience utilisateur.
        </p>
      </div>

      {
        projects.length === 0 ? (
          <div class="flex flex-col items-center justify-center rounded-2xl border border-dashed border-zinc-300 py-24 text-center dark:border-zinc-700">
            <p class="text-zinc-600 dark:text-zinc-400">
              Aucun projet pour l'instant.
            </p>
          </div>
        ) : (
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {projects.map((project) => (
              <a
                href={`/projects/${project.id}`}
                class="group flex flex-col overflow-hidden rounded-2xl border border-zinc-200 bg-zinc-50 transition-all hover:-translate-y-0.5 hover:border-indigo-400 dark:border-zinc-800 dark:bg-zinc-900/40 dark:hover:border-indigo-600"
              >
                {project.data.coverImage ? (
                  <div class="aspect-video overflow-hidden">
                    <img
                      src={
                        typeof project.data.coverImage === "string"
                          ? project.data.coverImage
                          : project.data.coverImage.src
                      }
                      alt={project.data.title}
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    />
                  </div>
                ) : (
                  <div class="flex aspect-video items-center justify-center bg-gradient-to-br from-indigo-100 to-violet-100 dark:from-indigo-950 dark:to-violet-950">
                    <Icon
                      name="lucide:rocket"
                      class="h-12 w-12 text-indigo-500 dark:text-indigo-400"
                    />
                  </div>
                )}
                <div class="flex flex-1 flex-col gap-3 p-6">
                  {project.data.type && (
                    <span class="w-fit rounded-full bg-indigo-600/10 px-3 py-1 text-xs font-medium text-indigo-600 dark:bg-indigo-500/20 dark:text-indigo-300">
                      {project.data.type}
                    </span>
                  )}
                  <h3 class="text-xl font-bold text-zinc-900 dark:text-zinc-50">
                    {project.data.title}
                  </h3>
                  <p class="text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
                    {project.data.description}
                  </p>
                  <div class="mt-auto flex flex-wrap gap-2 pt-3">
                    {project.data.tags.map((tag) => (
                      <span class="rounded-full border border-zinc-200 bg-zinc-100 px-2.5 py-0.5 text-xs text-zinc-700 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-300">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
              </a>
            ))}
          </div>
        )
      }
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  h1 {
    font-family: "DM Serif Display", serif;
  }
</style>
