---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Card from "../../components/Card.astro";

const projects = (await getCollection("projects")).sort(
  (a, b) =>
    new Date(b.data.publishedAt).getTime() -
    new Date(a.data.publishedAt).getTime(),
);
---

<BaseLayout title="Projets" description="Mes projets et réalisations">
  <Nav currentPath="/projects" />

  <main class="projects-page">
    <div class="projects-wrapper">
      <header class="projects-header">
        <div class="section-tag">Realisations</div>
        <h1 class="section-title">Mes <em>projets</em></h1>
        <p class="section-sub">
          Une selection de projets personnels et professionnels axes sur la
          qualite de code, la performance et l'experience utilisateur.
        </p>
      </header>

      <section class="projects-all">
        <div class="projects-label">Tous les projets</div>
        <div class="projects-grid">
          {
            projects.map((project) => (
              <Card
                href={`/projects/${project.slug}`}
                title={project.data.title}
                description={project.data.description}
                tags={project.data.tags}
                coverImage={project.data.coverImage?.src}
              />
            ))
          }
        </div>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .projects-page {
    min-height: 100vh;
    padding: 6rem clamp(2.4rem, 5vw, 8rem) 12rem;
  }

  .projects-wrapper {
    width: 100%;
    max-width: 144rem;
    margin: 0 auto;
  }

  .projects-header {
    max-width: 64rem;
    margin-bottom: 6.4rem;
  }

  .projects-label {
    margin-bottom: 2rem;
    font-family: "DM Mono", monospace;
    font-size: 1.1rem;
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(30rem, 1fr));
    gap: 2rem;
  }

  @media (width <= 70rem) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
