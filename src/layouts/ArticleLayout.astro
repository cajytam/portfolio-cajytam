---
import BaseLayout from "./BaseLayout.astro";
import AppHeader from "../components/AppHeader.astro";
import Footer from "../components/Footer.astro";
import { Icon } from "astro-icon/components";
import type { ArticleLayoutProps } from "../types";
import { categoryLabels } from "../types";

type Props = ArticleLayoutProps;

const { title, publishedAt, excerpt, category, tags, coverImage } = Astro.props;

const dateStr = publishedAt.toLocaleDateString("fr-FR", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const coverSrc =
  typeof coverImage === "string"
    ? coverImage
    : coverImage
      ? coverImage.src
      : null;
---

<BaseLayout title={`${title} — Cédric Matyja`} description={excerpt}>
  <AppHeader mode="page" />

  <main class="min-h-screen pt-16">
    <div class="relative h-[60vh] overflow-hidden">
      {
        coverSrc ? (
          <img src={coverSrc} alt={title} class="h-full w-full object-cover" />
        ) : (
          <div class="h-full w-full bg-linear-to-br from-indigo-900 via-zinc-900 to-zinc-950" />
        )
      }
      <div
        class="absolute inset-0 bg-linear-to-t from-zinc-50 via-zinc-50/50 to-transparent dark:from-zinc-950 dark:via-zinc-950/50"
      >
      </div>
    </div>

    <article class="relative z-10 mx-auto -mt-32 max-w-4xl px-6">
      <div class="mb-6 flex flex-wrap gap-2">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 rounded-full border border-zinc-300 bg-white/70 px-4 py-2 text-sm font-medium text-zinc-700 backdrop-blur-md transition-colors hover:border-indigo-400 hover:text-indigo-600 dark:border-zinc-700 dark:bg-zinc-900/70 dark:text-zinc-300 dark:hover:border-indigo-600 dark:hover:text-indigo-400"
        >
          <Icon name="lucide:arrow-left" class="h-4 w-4" />
          Retour au blog
        </a>
        <span
          class="rounded-full bg-indigo-600 px-4 py-2 text-sm font-medium text-white"
        >
          {categoryLabels[category] ?? category}
        </span>
        {
          tags.map((tag) => (
            <span class="rounded-full border border-zinc-300 bg-white/70 px-4 py-2 text-sm text-zinc-700 backdrop-blur-md dark:border-zinc-700 dark:bg-zinc-900/70 dark:text-zinc-300">
              #{tag}
            </span>
          ))
        }
      </div>

      <h1
        class="mb-8 font-serif text-5xl leading-tight font-bold text-zinc-900 lg:text-7xl dark:text-zinc-50"
      >
        {title}
      </h1>

      <div
        class="mb-12 flex items-center gap-6 text-zinc-500 dark:text-zinc-400"
      >
        <div class="flex items-center gap-2">
          <Icon name="lucide:calendar" class="h-5 w-5" />
          {dateStr}
        </div>
      </div>

      <p class="mb-12 text-xl leading-relaxed text-zinc-700 dark:text-zinc-300">
        {excerpt}
      </p>

      <div class="article-prose">
        <slot />
      </div>
    </article>

    <div class="h-32"></div>
  </main>

  <Footer />
</BaseLayout>

<style>
  h1 {
    font-family: "DM Serif Display", serif;
  }

  .article-prose {
    font-size: 1.05rem;
    line-height: 1.8;
    color: rgb(82 82 91);
  }

  :global(.dark) .article-prose {
    color: rgb(212 212 216);
  }

  .article-prose :global(h2) {
    margin: 3rem 0 1rem;
    font-family: "DM Serif Display", serif;
    font-size: 1.875rem;
    font-weight: 700;
    color: rgb(24 24 27);
  }

  :global(.dark) .article-prose :global(h2) {
    color: rgb(250 250 250);
  }

  .article-prose :global(h3) {
    margin: 2rem 0 0.75rem;
    font-size: 1.375rem;
    font-weight: 600;
    color: rgb(24 24 27);
  }

  :global(.dark) .article-prose :global(h3) {
    color: rgb(250 250 250);
  }

  .article-prose :global(p) {
    margin-bottom: 1.5rem;
  }

  .article-prose :global(a) {
    color: rgb(99 102 241);
    text-decoration: underline;
  }

  .article-prose :global(a:hover) {
    color: rgb(129 140 248);
  }

  .article-prose :global(strong) {
    font-weight: 600;
    color: rgb(24 24 27);
  }

  :global(.dark) .article-prose :global(strong) {
    color: rgb(250 250 250);
  }

  .article-prose :global(ul),
  .article-prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .article-prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .article-prose :global(pre) {
    padding: 1.5rem;
    margin: 2rem 0;
    overflow-x: auto;
    font-family: "DM Mono", ui-monospace, monospace;
    font-size: 0.875rem;
    line-height: 1.7;
    color: rgb(228 228 231);
    background: rgb(24 24 27);
    border: 1px solid rgb(63 63 70);
    border-radius: 1rem;
  }

  .article-prose :global(:not(pre) > code) {
    padding: 0.15rem 0.4rem;
    font-family: "DM Mono", monospace;
    font-size: 0.85em;
    color: rgb(99 102 241);
    background: rgb(99 102 241 / 10%);
    border: 1px solid rgb(99 102 241 / 20%);
    border-radius: 0.35rem;
  }

  .article-prose :global(blockquote) {
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    color: rgb(161 161 170);
    border-left: 3px solid rgb(99 102 241);
    background: rgb(99 102 241 / 6%);
    border-radius: 0 0.75rem 0.75rem 0;
  }

  .article-prose :global(img) {
    width: 100%;
    margin: 2rem 0;
    border: 1px solid rgb(228 228 231);
    border-radius: 1rem;
  }

  :global(.dark) .article-prose :global(img) {
    border-color: rgb(63 63 70);
  }

  .article-prose :global(hr) {
    margin: 3rem 0;
    border: none;
    border-top: 1px solid rgb(228 228 231);
  }

  :global(.dark) .article-prose :global(hr) {
    border-top-color: rgb(63 63 70);
  }
</style>
