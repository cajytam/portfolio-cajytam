---
import BaseLayout from "./BaseLayout.astro";
import Nav from "../components/Nav.astro";
import type { ArticleLayoutProps } from "../types";
import { categoryLabels } from "../types";

type Props = ArticleLayoutProps;

const { title, publishedAt, excerpt, category, tags, readingTime, coverImage } =
  Astro.props;

const dateStr = publishedAt.toLocaleDateString("fr-FR", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<BaseLayout title={`${title} — Cédric Matyja`} description={excerpt}>
  <Nav currentPath="/blog" />

  <main class="article-page">
    <div class="article-back">
      <a href="/blog" class="back-link">← Retour au blog</a>
    </div>

    <article class="article-container">
      <div class="article-tag-row">
        <span class="article-cat-tag"
          >{categoryLabels[category] ?? category}</span
        >
        {tags.map((tag) => <span class="article-cat-tag">{tag}</span>)}
      </div>

      <h1 class="article-title">{title}</h1>

      <div class="article-meta-row">
        <div class="article-avatar">AM</div>
        <div>
          <div class="article-author">Cédric Matyja</div>
          <div class="article-date">{dateStr}</div>
        </div>
        <div class="article-read-time">⏱ {readingTime} min de lecture</div>
      </div>

      {
        coverImage && (
          <div class="article-cover">
            <img src={coverImage} alt={title} />
          </div>
        )
      }

      <p class="article-lead">{excerpt}</p>

      <div class="article-body prose">
        <slot />
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  .article-page {
    min-height: 100vh;
    padding: 10rem clamp(2.4rem, 5vw, 8rem) 12rem;
  }

  .article-back {
    max-width: 78rem;
    margin: 0 auto 4rem;
  }

  .back-link {
    font-family: "DM Mono", monospace;
    font-size: 1.3rem;
    color: var(--text3);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--accent2);
  }

  .article-container {
    max-width: 78rem;
    margin: 0 auto;
  }

  .article-tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-bottom: 2rem;
  }

  .article-cat-tag {
    padding: 0.4rem 1.2rem;
    font-family: "DM Mono", monospace;
    font-size: 1.1rem;
    color: var(--accent2);
    letter-spacing: 0.08em;
    background: rgb(124 109 250 / 12%);
    border: 1px solid rgb(124 109 250 / 20%);
    border-radius: 0.6rem;
  }

  .article-title {
    margin-bottom: 2rem;
    font-family: "DM Serif Display", serif;
    font-size: clamp(3rem, 4vw, 4.8rem);
    line-height: 1.12;
    letter-spacing: -0.15rem;
  }

  .article-meta-row {
    display: flex;
    gap: 1.6rem;
    align-items: center;
    padding: 1.6rem 0;
    margin-bottom: 3.6rem;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .article-avatar {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: 3.8rem;
    height: 3.8rem;
    font-size: 1.4rem;
    font-weight: 700;
    color: #fff;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border-radius: 50%;
  }

  .article-author {
    font-size: 1.4rem;
    font-weight: 500;
  }

  .article-date {
    font-family: "DM Mono", monospace;
    font-size: 1.25rem;
    color: var(--text3);
  }

  .article-read-time {
    padding: 0.4rem 1.2rem;
    margin-left: auto;
    font-size: 1.2rem;
    color: var(--text3);
    white-space: nowrap;
    border: 1px solid var(--border);
    border-radius: 100px;
  }

  .article-lead {
    padding-left: 2rem;
    margin-bottom: 3.6rem;
    font-size: 1.8rem;
    font-weight: 300;
    line-height: 1.8;
    color: var(--text2);
    border-left: 2px solid var(--accent);
  }

  .article-cover {
    width: 100%;
    max-width: 78rem;
    aspect-ratio: 16 / 9;
    margin: 0 auto 4rem;
    overflow: hidden;
    border-radius: var(--radius-lg);
  }

  .article-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .prose {
    font-size: 1.55rem;
    font-weight: 300;
    line-height: 1.85;
    color: var(--text2);
  }

  .prose :global(p) {
    margin-bottom: 2.4rem;
  }

  .prose :global(h2) {
    margin: 4.8rem 0 1.6rem;
    font-family: "DM Serif Display", serif;
    font-size: 2.6rem;
    color: var(--text);
    letter-spacing: -0.05rem;
  }

  .prose :global(h3) {
    margin: 2.8rem 0 1.2rem;
    font-size: 1.7rem;
    font-weight: 500;
    color: var(--text);
  }

  .prose :global(strong) {
    font-weight: 500;
    color: var(--text);
  }

  .prose :global(em) {
    color: var(--text2);
  }

  .prose :global(a) {
    color: var(--accent2);
    text-decoration: underline;
  }

  .prose :global(a:hover) {
    color: var(--text);
  }

  /************************
  * Blocs de code (Shiki) *
  ************************/
  .prose :global(pre) {
    position: relative;
    padding: 2rem 2.4rem;
    margin: 2.8rem 0;
    overflow-x: auto;
    font-family: "DM Mono", monospace;
    font-size: 1.3rem;
    line-height: 1.8;
    background: var(--bg3) !important;
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .prose :global(pre::before) {
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    height: 1px;
    content: "";
    background: linear-gradient(90deg, var(--accent), transparent);
    opacity: 0.4;
  }

  .prose :global(code) {
    font-family: "DM Mono", monospace;
    font-size: 1.3rem;
  }

  /************************
  * code en ligne *
  ************************/
  .prose :global(:not(pre) > code) {
    padding: 0.2rem 0.7rem;
    font-size: 0.88em;
    color: var(--accent2);
    background: rgb(124 109 250 / 10%);
    border: 1px solid rgb(124 109 250 / 20%);
    border-radius: 0.4rem;
  }

  .prose :global(blockquote) {
    padding: 2rem 2.4rem;
    margin: 3.2rem 0;
    font-style: normal;
    color: var(--text2);
    background: rgb(245 158 11 / 6%);
    border: 1px solid rgb(245 158 11 / 20%);
    border-left: 3px solid var(--amber);
    border-radius: var(--radius);
  }

  .prose :global(blockquote strong) {
    color: var(--amber);
  }

  .prose :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 2.4rem;
    margin-bottom: 2.4rem;
  }

  .prose :global(li) {
    margin-bottom: 0.8rem;
  }

  .prose :global(img) {
    width: 100%;
    margin: 3.2rem 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .prose :global(hr) {
    margin: 4.8rem 0;
    border: none;
    border-top: 1px solid var(--border);
  }
</style>
