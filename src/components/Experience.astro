---
import { Icon } from "astro-icon/components";

const experiences = [
  {
    company: "Cheef.fr",
    location: "Roncq",
    role: "Développeur Full Stack",
    period: "2024 - Présent",
    tasks: [
      "Application de gestion et suivi des leads (React + Symfony/API Platform)",
      "Application de suivi des tickets support avec KPIs",
      "Affichage du statut Aircall en temps réel via Mercure/SSE dans PrestaShop",
      "Intégration API/webhooks (Brevo, Aircall)",
      "Automatisation de la mise en production avec Docker Compose",
    ],
    tags: [
      "React",
      "Symfony",
      "API Platform",
      "PrestaShop",
      "Docker",
      "Mercure",
    ],
  },
  {
    company: "Enbro France / Earth Solar France",
    location: "Roncq",
    role: "Développeur Web",
    period: "2023 - 2024",
    tasks: [
      "Développement d'un CRM pour la gestion des prospects et projets photovoltaïques",
      "Génération automatisée de devis avec calculs de dimensionnement et ROI",
      "Gestion des documents administratifs et d'installation de projets",
    ],
    tags: ["Vue.js", "Symfony", "API Platform", "MySQL"],
  },
  {
    company: "Dornach France (Groupe Ziegler)",
    location: "Roncq",
    role: "Analyste Programmeur EDI",
    period: "2022 - 2023",
    tasks: [
      "Programmes de traduction de fichiers en langage TradeXpress RTE",
      "Gestion des tickets via Jira",
    ],
    tags: ["RTE", "TradeXpress", "EDI", "Jira"],
  },
  {
    company: "Association Noémi",
    location: "Roubaix",
    role: "Développeur Web",
    period: "2019 - 2022",
    tasks: [
      "Refonte du site web avec Symfony",
      "Conception UML et intégration front-end",
      "Back-office sécurisé pour la gestion de contenu",
      "Génération de reçus PDF et envoi par e-mail",
      "Tests unitaires et fonctionnels",
    ],
    tags: ["Symfony", "UML", "PDF", "Back-office"],
  },
  {
    company: "Castorama France SAS",
    location: "Templemars",
    role: "Administrateur SI Finance & Amélioration Continue",
    period: "2013 - 2022",
    tasks: [
      "Gestion des logiciels comptables CODA et SAP",
      "Développement d'outils d'automatisation Python/VBA pour l'optimisation des traitements",
    ],
    tags: ["Python", "VBA", "SAP", "CODA"],
  },
  {
    company: "Castorama France SAS",
    location: "Templemars",
    role: "Comptable",
    period: "2010 - 2013",
    tasks: [
      "Traitement des factures, rapprochements et règlements",
      "Conformité fiscale/sociale et clôtures mensuelles/annuelles",
    ],
    tags: ["Comptabilité", "Administration"],
  },
];
---

<section id="experience" class="mx-auto max-w-7xl px-6 py-32 lg:px-12">
  <div>
    <div
      class="mb-4 text-sm font-medium tracking-wider text-indigo-500 dark:text-indigo-400"
    >
      PARCOURS PROFESSIONNEL
    </div>

    <h2
      class="mb-20 font-serif text-5xl font-bold text-zinc-900 lg:text-6xl dark:text-zinc-50"
    >
      Expérience
    </h2>

    <div class="space-y-12">
      {
        experiences.map((exp) => (
          <div class="group relative border-l-2 border-zinc-200 pl-12 transition-colors hover:border-indigo-500 dark:border-zinc-800 dark:hover:border-indigo-600">
            <div class="absolute top-0 left-0 h-4 w-4 -translate-x-[0.5625rem] rounded-full border-4 border-zinc-50 bg-zinc-200 transition-colors group-hover:bg-indigo-500 dark:border-zinc-950 dark:bg-zinc-800 dark:group-hover:bg-indigo-600" />

            <div class="pb-12">
              <div class="mb-4 flex flex-wrap items-start justify-between gap-4">
                <div>
                  <h3 class="mb-1 text-2xl font-bold text-zinc-900 dark:text-zinc-50">
                    {exp.role}
                  </h3>
                  <div class="flex items-center gap-2 text-zinc-500 dark:text-zinc-400">
                    <Icon name="lucide:briefcase" class="h-4 w-4" />
                    <span>
                      {exp.company}, {exp.location}
                    </span>
                  </div>
                </div>
                <div class="font-medium text-indigo-500 dark:text-indigo-400">
                  {exp.period}
                </div>
              </div>

              <ul class="mb-4 space-y-1.5">
                {exp.tasks.map((task) => (
                  <li class="flex items-start gap-2 leading-relaxed text-zinc-600 dark:text-zinc-400">
                    <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-indigo-500 dark:bg-indigo-400" />
                    {task}
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap gap-2">
                {exp.tags.map((tag) => (
                  <span class="rounded-full border border-zinc-200 bg-zinc-100 px-3 py-1 text-sm text-zinc-700 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-300">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  h2 {
    font-family: "DM Serif Display", serif;
  }
</style>
