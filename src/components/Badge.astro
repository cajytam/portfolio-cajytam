---
interface Props {
  variant?: "default" | "primary" | "success" | "amber";
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { variant = "default", size = "md", class: className = "" } = Astro.props;
---

<span class:list={["badge", `badge-${variant}`, `badge-${size}`, className]}>
  <slot />
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    font-weight: 500;
    white-space: nowrap;
    user-select: none;
    border-radius: 100px;
    transition: all 0.3s ease;
  }

  .badge-sm {
    padding: 0.3rem 0.9rem;
    font-size: 0.85rem;
  }

  .badge-md {
    padding: 0.4rem 1rem;
    font-size: 0.95rem;
  }

  .badge-lg {
    padding: 0.6rem 1.4rem;
    font-size: 1rem;
  }

  /* Variants */
  .badge-default {
    color: var(--text2);
    background: var(--bg3);
    border: 1px solid var(--border2);
  }

  .badge-default:hover {
    background: var(--bg2);
    border-color: var(--border);
  }

  .badge-primary {
    color: var(--accent);
    background: rgb(59 130 246 / 10%);
    border: 1px solid rgb(59 130 246 / 20%);
  }

  .badge-primary:hover {
    background: rgb(59 130 246 / 15%);
    border-color: rgb(59 130 246 / 35%);
  }

  .badge-success {
    color: var(--green);
    background: rgb(16 185 129 / 10%);
    border: 1px solid rgb(16 185 129 / 20%);
  }

  .badge-success:hover {
    background: rgb(16 185 129 / 15%);
    border-color: rgb(16 185 129 / 35%);
  }

  .badge-amber {
    color: var(--amber);
    background: rgb(245 158 11 / 10%);
    border: 1px solid rgb(245 158 11 / 20%);
  }

  .badge-amber:hover {
    background: rgb(245 158 11 / 15%);
    border-color: rgb(245 158 11 / 35%);
  }
</style>
