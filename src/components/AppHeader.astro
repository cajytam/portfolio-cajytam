---
import { Icon } from "astro-icon/components";

interface Props {
  mode?: "home" | "page";
}

const { mode = "home" } = Astro.props;

const homeLinks = [
  { label: "Accueil", href: "#accueil", id: "accueil" },
  { label: "Expérience", href: "#experience", id: "experience" },
  { label: "Formation", href: "#formation", id: "formation" },
  { label: "Stack", href: "#stack", id: "stack" },
  { label: "Blog", href: "#blog", id: "blog" },
];

const pageLinks = [
  { label: "Accueil", href: "/", id: "home" },
  { label: "Blog", href: "/blog", id: "blog" },
  { label: "Projets", href: "/projects", id: "projects" },
];

const navLinks = mode === "home" ? homeLinks : pageLinks;
---

<header
  class="fixed top-0 right-0 left-0 z-50 border-b border-zinc-200 bg-white/80 backdrop-blur-lg transition-colors dark:border-zinc-800 dark:bg-zinc-950/80"
  data-app-header
  data-mode={mode}
>
  <div
    class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6 lg:px-12"
  >
    <a
      href={mode === "home" ? "#accueil" : "/"}
      class="nav-logo font-serif text-[2rem] leading-none tracking-[-0.05rem] text-zinc-900 no-underline dark:text-zinc-50"
      aria-label="Retour à l'accueil"
      data-close-menu
    >
      CM<span class="text-indigo-500 dark:text-indigo-400">.</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            data-nav-link
            data-section={link.id}
            class="relative px-3 py-2 text-sm font-medium text-zinc-600 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100"
          >
            {link.label}
            <span
              data-nav-underline
              class="absolute right-3 bottom-0 left-3 h-0.5 origin-left scale-x-0 rounded-full bg-indigo-500 opacity-0 transition-all duration-300 dark:bg-indigo-400"
            />
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <button
        type="button"
        data-theme-toggle
        class="flex h-9 w-9 items-center justify-center rounded-lg text-zinc-500 transition-colors hover:bg-zinc-100 hover:text-zinc-900 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-100"
        aria-label="Basculer le thème"
      >
        <Icon
          name="lucide:sun"
          class="hidden h-[1.125rem] w-[1.125rem] dark:block"
        />
        <Icon
          name="lucide:moon"
          class="block h-[1.125rem] w-[1.125rem] dark:hidden"
        />
      </button>

      <button
        type="button"
        data-mobile-toggle
        class="flex h-9 w-9 items-center justify-center rounded-lg text-zinc-500 transition-colors hover:bg-zinc-100 hover:text-zinc-900 md:hidden dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-100"
        aria-label="Menu"
      >
        <Icon name="lucide:menu" data-icon-menu class="h-5 w-5" />
        <Icon name="lucide:x" data-icon-close class="hidden h-5 w-5" />
      </button>
    </div>
  </div>

  <div
    data-mobile-menu
    hidden
    class="border-t border-zinc-200 bg-white/95 backdrop-blur-lg md:hidden dark:border-zinc-800 dark:bg-zinc-950/95"
  >
    <nav class="mx-auto flex max-w-7xl flex-col gap-1 px-6 py-4">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            data-nav-link-mobile
            data-section={link.id}
            data-close-menu
            class="rounded-lg px-3 py-2.5 text-sm font-medium text-zinc-700 transition-colors hover:bg-zinc-100 hover:text-zinc-900 dark:text-zinc-300 dark:hover:bg-zinc-800 dark:hover:text-zinc-100"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  .nav-logo {
    font-family: "DM Serif Display", serif;
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>("[data-app-header]");
  if (header) {
    const mode = header.dataset.mode ?? "home";
    const mobileToggle = header.querySelector<HTMLButtonElement>(
      "[data-mobile-toggle]",
    );
    const mobileMenu = header.querySelector<HTMLElement>("[data-mobile-menu]");
    const iconMenu = header.querySelector<HTMLElement>("[data-icon-menu]");
    const iconClose = header.querySelector<HTMLElement>("[data-icon-close]");
    const themeToggle = header.querySelector<HTMLButtonElement>(
      "[data-theme-toggle]",
    );
    const closeBtns =
      document.querySelectorAll<HTMLElement>("[data-close-menu]");

    function setMenu(open: boolean) {
      if (!mobileMenu || !iconMenu || !iconClose) return;
      if (open) {
        mobileMenu.removeAttribute("hidden");
        iconMenu.classList.add("hidden");
        iconClose.classList.remove("hidden");
      } else {
        mobileMenu.setAttribute("hidden", "");
        iconMenu.classList.remove("hidden");
        iconClose.classList.add("hidden");
      }
    }

    mobileToggle?.addEventListener("click", () => {
      setMenu(mobileMenu?.hasAttribute("hidden") ?? true);
    });

    closeBtns.forEach((el) =>
      el.addEventListener("click", () => setMenu(false)),
    );

    themeToggle?.addEventListener("click", () => {
      const root = document.documentElement;
      const isDark = root.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });

    if (mode === "home") {
      const links = header.querySelectorAll<HTMLElement>(
        "[data-nav-link], [data-nav-link-mobile]",
      );
      const sectionIds = [
        "accueil",
        "experience",
        "formation",
        "stack",
        "blog",
      ];
      const sections = sectionIds
        .map((id) => document.getElementById(id))
        .filter((el): el is HTMLElement => el !== null);

      function setActive(id: string) {
        links.forEach((link) => {
          const isActive = link.dataset.section === id;
          const underline = link.querySelector<HTMLElement>(
            "[data-nav-underline]",
          );
          if (link.matches("[data-nav-link]")) {
            link.classList.toggle("text-zinc-900", isActive);
            link.classList.toggle("dark:text-zinc-50", isActive);
            link.classList.toggle("text-zinc-600", !isActive);
            link.classList.toggle("dark:text-zinc-400", !isActive);
            underline?.classList.toggle("scale-x-100", isActive);
            underline?.classList.toggle("opacity-100", isActive);
            underline?.classList.toggle("scale-x-0", !isActive);
            underline?.classList.toggle("opacity-0", !isActive);
          } else {
            link.classList.toggle("bg-zinc-100", isActive);
            link.classList.toggle("dark:bg-zinc-800", isActive);
            link.classList.toggle("text-zinc-900", isActive);
            link.classList.toggle("dark:text-zinc-50", isActive);
          }
        });
      }

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              setActive(entry.target.id);
            }
          }
        },
        { rootMargin: "-40% 0px -55% 0px", threshold: 0 },
      );

      sections.forEach((s) => observer.observe(s));
    }
  }
</script>
